# SEO AI - E2E Test Configuration
# Copy this file to .env.test and fill in your credentials
#
# If using Redis object cache and login fails after a password change,
# flush the cache first: docker exec <redis-container> redis-cli FLUSHALL

WP_BASE_URL=http://localhost:8080
WP_ADMIN_USER=admin
WP_ADMIN_PASS=your_password_here
